<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
  "-//Hibernate/Hibernate Mapping DTD//EN"
  "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
  <class name="com.klan.otakuverse.auth.domain.Role" table="roles">

    <id name="id" column="id" type="uuid-binary"/>
    <property name="role" type="string" length="255"/>
    <property name="createdAt" column="created_at" type="timestamp"/>
    <property name="updatedAt" column="updated_at" type="timestamp"/>

    <set name="permissions" table="roles_permissions" cascade="save-update" lazy="true">
      <key column="role_id"/>
      <many-to-many class="com.klan.otakuverse.auth.domain.Permission" column="permission_id" fetch="select"/>
    </set>
  </class>
</hibernate-mapping>
