<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
  "-//Hibernate/Hibernate Mapping DTD//EN"
  "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
  <class name="com.klan.otakuverse.character_roles.domain.CharacterRole" table="character_roles">

    <id name="id" column="id" type="uuid-binary"/>
    <property name="role" type="string" length="255"/>
    <property name="createdAt" column="created_at" type="timestamp"/>
    <property name="updatedAt" column="updated_at" type="timestamp"/>

  </class>
</hibernate-mapping>
