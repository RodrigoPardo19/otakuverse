<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
  "-//Hibernate/Hibernate Mapping DTD//EN"
  "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
  <class name="com.klan.otakuverse.ovas.domain.OVA" table="ovas">

    <id name="id" column="id" type="uuid-binary"/>
    <property name="name" type="text"/>
    <property name="releaseDate" column="release_date" type="date"/>
    <property name="cover" type="string" length="255"/>
    <property name="createdAt" column="created_at" type="timestamp"/>
    <property name="updatedAt" column="updated_at" type="timestamp"/>

    <many-to-one name="anime" class="com.klan.otakuverse.animes.domain.Anime" column="anime_id"/>

    <set name="studios" table="studios_ovas" cascade="save-update" lazy="true">
      <key column="ova_id"/>
      <many-to-many class="com.klan.otakuverse.studios.domain.Studio" column="studio_id" fetch="select"/>
    </set>

    <set name="producers" table="producers_ovas" cascade="save-update" lazy="true">
      <key column="ova_id"/>
      <many-to-many class="com.klan.otakuverse.producers.domain.Producer" column="producer_id" fetch="select"/>
    </set>
  </class>
</hibernate-mapping>
