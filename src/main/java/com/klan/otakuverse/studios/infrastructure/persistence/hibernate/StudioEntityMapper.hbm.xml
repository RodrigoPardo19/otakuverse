<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
  "-//Hibernate/Hibernate Mapping DTD//EN"
  "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
  <class name="com.klan.otakuverse.studios.domain.Studio" table="studios">

    <id name="id" column="id" type="uuid-binary"/>
    <property name="name" type="text"/>
    <property name="description" type="text"/>
    <property name="establishedAt" column="established_at" type="date"/>
    <property name="webSite" type="string" length="255"/>
    <property name="cover" type="string" length="255"/>
    <property name="createdAt" column="created_at" type="timestamp"/>
    <property name="updatedAt" column="updated_at" type="timestamp"/>

    <set name="animes" inverse="true" lazy="true">
      <key column="studio_id"/>
      <many-to-many class="com.klan.otakuverse.animes.domain.Anime"/>
    </set>

    <set name="movies" inverse="true" lazy="true">
      <key column="studio_id"/>
      <many-to-many class="com.klan.otakuverse.movies.domain.Movie"/>
    </set>

    <set name="ovas" inverse="true" lazy="true">
      <key column="studio_id"/>
      <many-to-many class="com.klan.otakuverse.ovas.domain.OVA"/>
    </set>

    <set name="onas" inverse="true" lazy="true">
      <key column="studio_id"/>
      <many-to-many class="com.klan.otakuverse.onas.domain.ONA"/>
    </set>
  </class>
</hibernate-mapping>
