<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
  "-//Hibernate/Hibernate Mapping DTD//EN"
  "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
  <class name="com.klan.otakuverse.characters.domain.Character" table="characters">

    <id name="id" column="id" type="uuid-binary"/>
    <property name="fullName" column="full_name" type="string" length="255"/>
    <property name="alias" type="string" length="255"/>
    <property name="cover" type="string" length="255"/>
    <property name="description" type="text"/>
    <property name="createdAt" column="created_at" type="timestamp"/>
    <property name="updatedAt" column="updated_at" type="timestamp"/>

  </class>
</hibernate-mapping>
